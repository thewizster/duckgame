{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@engine/*": ["./engine/*"]
    }
  },
  "include": ["engine/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
